{
  "manifest_version": 3,
  "name": "Scrollagotchi",
  "version": "0.1.0",
  "description": "A Tamagotchi that dies if you stop scrolling.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["http://localhost:8787/*", "https://www.instagram.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.instagram.com/reels/*", "https://www.instagram.com/*"],
      "js": ["content/instagramReels.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/stickySidebar.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrollagotchi"
  }
}
