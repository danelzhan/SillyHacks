{
  "manifest_version": 3,
  "name": "Scrollagotchi",
  "version": "0.1.0",
  "description": "A Tamagotchi that dies if you stop scrolling.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": [
    "http://localhost:8787/*",
    "http://127.0.0.1:8787/*",
    "https://www.instagram.com/*",
    "https://www.tiktok.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.instagram.com/reels/*",
        "https://www.instagram.com/*",
        "https://www.tiktok.com/*"
      ],
      "js": ["content/instagramReels.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["http://*/*", "https://*/*"],
      "js": ["content/stickySidebar.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Scrollagotchi"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "assets/dog_happy.png",
        "assets/dog_sleep.png",
        "assets/dog_confused.png",
        "assets/dogtear.png",
        "assets/dogghost.png",
        "assets/dogdead.png"
      ],
      "matches": ["http://*/*", "https://*/*"]
    }
  ]
}
